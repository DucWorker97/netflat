{
    "name": "netflat",
    "version": "0.0.1",
    "private": true,
    "packageManager": "pnpm@9.15.0",
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "lint": "turbo run lint",
        "typecheck": "turbo run typecheck",
        "clean": "turbo run clean && rm -rf node_modules",
        "verify": "bash scripts/ci/verify.sh",
        "smoke": "bash scripts/ci/smoke.sh",
        "smoke:video": "bash scripts/ci/video-pipeline-smoke.sh",
        "infra:up": "docker compose up -d",
        "infra:down": "docker compose down",
        "infra:logs": "docker compose logs -f",
        "infra:reset": "docker compose down -v && docker compose up -d",
        "db:generate": "pnpm --filter @netflat/api prisma generate",
        "db:migrate": "pnpm --filter @netflat/api prisma migrate dev",
        "db:migrate:deploy": "pnpm --filter @netflat/api prisma migrate deploy",
        "db:prepare:local": "pnpm --filter @netflat/api prisma db push --accept-data-loss && pnpm --filter @netflat/api run db:seed",
        "db:seed": "pnpm --filter @netflat/api prisma db seed",
        "db:studio": "pnpm --filter @netflat/api prisma studio",
        "db:reset": "pnpm --filter @netflat/api prisma migrate reset --force",
        "smoke:health": "curl -s http://localhost:3000/health | jq .",
        "release:check": "pnpm lint && pnpm typecheck && pnpm build && pnpm smoke:video && echo '✅ RELEASE CHECK PASSED'",
        "demo:prep": "pnpm infra:up && pnpm db:prepare:local && echo '✅ DEMO PREP COMPLETE'",
        "deploy:staging": "docker compose -f deploy/docker-compose.staging.yml --env-file deploy/.env.staging up -d --build",
        "deploy:staging:down": "docker compose -f deploy/docker-compose.staging.yml down",
        "deploy:staging:logs": "docker compose -f deploy/docker-compose.staging.yml logs -f",
        "dev:core": "turbo run dev --filter=@netflat/api --filter=@netflat/admin --filter=@netflat/web",
        "dev:web": "node scripts/use-env.js .env.web.local && pnpm dev:core",
        "dev:runtime:doctor": "node scripts/dev-runtime.js doctor --mode web",
        "dev:runtime:start": "node scripts/dev-runtime.js start --mode web --force-ports",
        "dev:runtime:web": "node scripts/dev-runtime.js start --mode web --force-ports",
        "dev:runtime:stop": "node scripts/dev-runtime.js stop",
        "dev:runtime:status": "node scripts/dev-runtime.js status",
        "kill:ports": "npx kill-port 3000 9000 || true",
        "check:mojibake": "node scripts/check-mojibake.js",
        "fix:mojibake": "node scripts/fix-mojibake.js"
    },
    "dependencies": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "turbo": "^2.3.0",
        "typescript": "^5.7.0",
        "prettier": "^3.4.0",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.2.0"
    }
}
