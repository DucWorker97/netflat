# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/netflat

# ─────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ─────────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production_use_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_too_another_long_random_string
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────
# Object Storage (MinIO / S3)
# ─────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9002
S3_PRESIGN_BASE_URL=http://localhost:9002
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=netflat-media
S3_REGION=us-east-1
S3_PUBLIC_BASE_URL=http://localhost:9002/netflat-media

# ─────────────────────────────────────────────────────────────
# Upload / Stream
# ─────────────────────────────────────────────────────────────
UPLOAD_MAX_MB=2048
UPLOAD_PRESIGNED_TTL_SECONDS=3600
STREAM_URL_TTL_SECONDS=3600

# ─────────────────────────────────────────────────────────────
# TMDB
# ─────────────────────────────────────────────────────────────
# TMDB_API_KEY=
# TMDB_READ_ACCESS_TOKEN=

# ─────────────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# ─────────────────────────────────────────────────────────────
# Admin Web (Next.js)
# ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3002
API_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_S3_PUBLIC_BASE_URL=http://localhost:9002/netflat-media
# NEXT_PUBLIC_ENABLE_SESSION_RECORDER=false

# ─────────────────────────────────────────────────────────────
# Billing / Payments
# ─────────────────────────────────────────────────────────────
PAYMENT_PROVIDER=mock
MOCK_WEBHOOK_SECRET=change_me_for_staging_or_production
# VNPAY_TMN_CODE=
# VNPAY_HASH_SECRET=
# VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# VNPAY_RETURN_URL=http://localhost:3000/api/payments/vnpay-return
# VNPAY_IPN_URL=http://localhost:3000/api/payments/vnpay-ipn
# VNPAY_ALLOW_RETURN_COMPLETION=false

# ─────────────────────────────────────────────────────────────
# Mail (disabled by default)
# Provider: none | smtp
# ─────────────────────────────────────────────────────────────
MAIL_ENABLED=false
MAIL_PROVIDER=smtp
MAIL_FROM=noreply@netflat.dev
MAIL_HOST=smtp.example.com
MAIL_PORT=587
# MAIL_USER=
# MAIL_PASS=
